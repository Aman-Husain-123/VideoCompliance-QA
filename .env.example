# --- AZURE STORAGE ---
AZURE_STORAGE_CONNECTION_STRING="your-connection-string"

# --- AZURE OPENAI (Chat & Reasoning)
AZURE_OPENAI_API_KEY="your-api-key"
AZURE_OPENAI_ENDPOINT="your-endpoint"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o"

# --- AZURE OPENAI (Embeddings)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"
AZURE_OPENAI_EMBEDDING_API_KEY="your-embedding-key"
AZURE_OPENAI_EMBEDDING_ENDPOINT="your-embedding-endpoint"

# --- AZURE AI SEARCH (The Knowledge Base) ---
AZURE_SEARCH_ENDPOINT="your-search-endpoint"
AZURE_SEARCH_API_KEY="your-search-key"
AZURE_SEARCH_INDEX_NAME="video-compliance-rules"

# --- AZURE VIDEO INDEXER (Identity Auth) ---
AZURE_VI_NAME="your-vi-resource-name"
AZURE_VI_LOCATION="eastus" # or "trial"
AZURE_VI_ACCOUNT_ID="your-account-id"
AZURE_SUBSCRIPTION_ID="your-subscription-id"
AZURE_RESOURCE_GROUP="your-resource-group"

# --- AZURE SERVICE PRINCIPAL ---
AZURE_CLIENT_ID="your-client-id"
AZURE_CLIENT_SECRET="your-client-secret"
AZURE_TENANT_ID="your-tenant-id"

# --- OBSERVABILITY ---
APPLICATIONINSIGHTS_CONNECTION_STRING="your-appinsights-conn-stri"

# --- LANGSMITH (Tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY="your-langchain-key"
LANGCHAIN_PROJECT="brand-guardian-prod"
